{
  "name": "@claude-doctor/cli",
  "version": "0.1.0",
  "description": "CLI tool to diagnose Claude Code configuration",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "diagnostic"
  ],
  "license": "MIT",
  "bin": {
    "claude-doctor": "./dist/index.mjs"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:serve": "nodemon --watch dist --exec 'node dist/index.mjs serve --no-open'",
    "lint": "oxlint src --fix && oxfmt --write src",
    "lint:check": "oxlint src && oxfmt --check src",
    "format": "oxfmt --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "nodemon": "^3.1.11",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "tsdown": "0.20.0-beta.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20.19"
  }
}
